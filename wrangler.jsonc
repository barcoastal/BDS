{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bdi",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-04",
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bdi-leads",
      "database_id": "REPLACE_WITH_D1_ID"
    }
  ],
  "vars": {}
}
