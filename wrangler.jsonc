{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bdi",
  "account_id": "1b2eccaf2ac50c85565dbbc1fa38a035",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-04",
  "assets": {
    "directory": "./out",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bdi-leads",
      "database_id": "67946f8c-a204-447c-9b2c-6f40772ff19a"
    }
  ],
  "vars": {}
}
